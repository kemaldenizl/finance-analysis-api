{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "SecurityService",
    "Audience": "SecurityService.Clients",
    "SigningKey": "super-long-development-signing-key-dummy-temp-devl-123456",
    "Key": "super-long-development-signing-key-dummy-temp-devl-123456",
    "AccessTokenLifetimeMinutes": 15
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "security-auth-route": {
        "ClusterId": "security-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "RateLimiterPolicy": "standard"
      },
      "security-mfa-route": {
        "ClusterId": "security-cluster",
        "Match": {
          "Path": "/api/mfa/{**catch-all}"
        },
        "RateLimiterPolicy": "standard"
      },
      "security-sessions-route": {
        "ClusterId": "security-cluster",
        "Match": {
          "Path": "/api/sessions/{**catch-all}"
        },
        "RateLimiterPolicy": "standard"
      },
      "security-users-route": {
        "ClusterId": "security-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "RateLimiterPolicy": "standard"
      },
      "security-test-route": {
        "ClusterId": "security-cluster",
        "Match": {
          "Path": "/api/test/{**catch-all}"
        },
        "RateLimiterPolicy": "standard"
      },
      "transactions-base-route": {
        "ClusterId": "transactions-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/transactions/{**catch-all}"
        },
        "RateLimiterPolicy": "standard"
      }
    },
    "Clusters": {
      "security-cluster": {
        "Destinations": {
          "security-api": {
            "Address": "http://localhost:5188/"
          }
        }
      },
      "transactions-cluster": {
        "Destinations": {
          "transactions-api": {
            "Address": "http://localhost:5036/"
          }
        }
      }
    }
  }
}
