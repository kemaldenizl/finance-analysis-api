{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "Security.API"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=kemal_db;Username=kemal;Password=kemal1234;",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "SecurityService",
    "Audience": "SecurityService.Clients",
    "SigningKey": "super-long-development-signing-key-dummy-temp-devl-123456",
    "AccessTokenLifetimeMinutes": 15
  },
  "IdentitySeed": {
    "Enabled": true,
    "AllowInProduction": false,
    "AdminEmail": "admin@local",
    "AdminPassword": "DummyPw123!"
  },
  "RedisRevocation": {
    "InstanceName": "security",
    "AccessTokenRevocationPrefix": "revoked:access:jti:"
  },
  "RateLimiting": {
    "Register": {
      "PermitLimit": 3,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true
    },
    "Login": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true
    },
    "Refresh": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true
    },
    "Logout": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true
    },
    "Sessions": {
      "PermitLimit": 20,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true
    },
    "ForgotPassword": {
      "PermitLimit": 3,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true
    },
    "ResetPassword": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true
    },
    "VerifyEmail": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true
    },
    "ResendVerification": {
      "PermitLimit": 3,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true
    }
  }
}
